# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# NextAuth Configuration
# Tip: You can generate a secret using `openssl rand -base64 32`
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional: Required for Social Login)
GITHUB_ID=""
GITHUB_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI Engine
# Required for the 'Platform AI' and free token features
OPENAI_API_KEY="sk-your-platform-key-here"
